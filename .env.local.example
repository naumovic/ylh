# Copy this file to `.env.local` (git-ignored) and fill in real values.
# Loaded automatically by the Node service in dev (server/index.ts → process.loadEnvFile).
# NEVER commit .env.local or paste these values into chat/PRs.

# --- Resend (server-only) ---------------------------------------------------
# API key from Resend → API Keys (use "Full access": needed for contacts + send).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Resend → Audiences → open your audience → copy its ID.
RESEND_AUDIENCE_ID=00000000-0000-0000-0000-000000000000

# Verified sender. For a quick test with NO domain setup, use onboarding@resend.dev
# (only delivers to your own Resend signup email). For real sending, verify a
# domain and use an address on it, e.g. "Your Local Hero <plan@mail.yourlocalhero.com.au>".
RESEND_FROM=onboarding@resend.dev

# --- PostHog (client, build-time) -------------------------------------------
# Inlined into the client bundle at build. Optional — analytics no-ops if unset.
# Project API key (starts with phc_). Safe to expose (it's a publishable client key).
VITE_POSTHOG_KEY=
# Match your PostHog region: https://us.i.posthog.com (default) or https://eu.i.posthog.com
VITE_POSTHOG_HOST=

# --- Server ----------------------------------------------------------------
# Port the Node service listens on locally (Render sets PORT itself in prod).
PORT=3000
